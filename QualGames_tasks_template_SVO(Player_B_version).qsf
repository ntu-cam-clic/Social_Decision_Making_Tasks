{"SurveyEntry":{"SurveyID":"SV_0d3rpeMXo7jedoO","SurveyName":"social DM task template_Player B version","SurveyDescription":null,"SurveyOwnerID":"UR_00YQzwC03iwzqyq","SurveyBrandID":"ntusingapore","DivisionID":"DV_eFf1ZgQBBuz3x66","SurveyLanguage":"EN","SurveyActiveResponseSet":"RS_5aQBJfOaF6ffJEW","SurveyStatus":"Active","SurveyStartDate":"0000-00-00 00:00:00","SurveyExpirationDate":"0000-00-00 00:00:00","SurveyCreationDate":"2026-04-27 21:32:55","CreatorID":"UR_00YQzwC03iwzqyq","LastModified":"2026-05-05 09:41:34","LastAccessed":"0000-00-00 00:00:00","LastActivated":"2026-04-29 23:32:19","Deleted":null},"SurveyElements":[{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"BL","PrimaryAttribute":"Survey Blocks","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":[{"Type":"Default","Description":"Social value orientation task","ID":"BL_5inCBaNJipGrHtY","BlockElements":[{"Type":"Question","QuestionID":"QID1"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID2"}]},{"Type":"Trash","Description":"Trash \/ Unused Questions","ID":"BL_2lYTj7vt5fwWCkm"}]},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"FL","PrimaryAttribute":"Survey Flow","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"Flow":[{"ID":"BL_5inCBaNJipGrHtY","Type":"Block","FlowID":"FL_2"}],"Properties":{"Count":2},"FlowID":"FL_1","Type":"Root"}},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"a4371d83-aa98-463f-acbb-a3d850984985"}},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"2","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"RS","PrimaryAttribute":"RS_5aQBJfOaF6ffJEW","SecondaryAttribute":"Default Response Set","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"DefaultMessage","Header":"<script>\n\/\/#########################################################################################################################-->\n\/\/########################################### Global functions and variables ##############################################-->\n\/\/#########################################################################################################################--> \nvar $ = jQuery; \/\/ restore jQuery reference    \n\/\/ Fisher-Yates shuffle--------------------------------------------------------------------------------\nfunction shuffle(o)\n\t    {\n\t\t\t\tfor(var j,x,i=o.length; i; j=Math.floor(Math.random()*i),x=o[--i],o[i]=o[j],o[j]=x);\n\t\t\t\treturn o;\n\t\t} \/\/ end of function shuffle--------------------------------------------------------------------------\n\t    \n\/\/ function sleep --------------------------------------------------------------------------------\nfunction sleep(milliseconds) {\n                   var date = Date.now();\n                   var currentDate = null;\n                do {currentDate = Date.now();\n                      } while (currentDate - date < milliseconds);\n        } \/\/ end of function sleep; sleep is used to pause for a short time, e.g. after button press, to make the transitioning smoother\n\nvar fadeinSpeed=700;  \/\/ to control fade in speed of some screens \nvar logTurnOn=1;   \/\/ to print some variables in the console for debugging\n \/\/ This and the next variable record the name and value of responses and \n \/\/ are saved into the embedded data with the same names.  \nvar all_variableNames=[];  \nvar all_variableValues=[];\n\n\/\/ load the csv file with participants responses\nasync function fetchCSVUntilSucceeded() {\n  let success = false;\n  while(!success) {\n    try {\n      const response = await fetch('https:\/\/ntusingapore.qualtrics.com\/ControlPanel\/File.php?F=F_g43VDS9qq8DkrWe');\n      const csvData = await response.text(); \/\/ Get as text\n\n      \/\/ Parse CSV into array for easier access\n      const cleanData = csvData.replace(\/\\r\\n\/g, '\\n');\n      const rows = cleanData.trim().split('\\n').map(line => line.split(','));\n      SVOchoices_CSV = rows;\n      \n      if (logTurnOn) {  \n        console.log(\"CSV parameter load: successful\");\n        console.log(\"First row:\", SVOchoices_CSV[0]);\n      }\n      \n      console.log(\"CSV loaded and stored\");\n      success = true;\n      \n    } catch (error) {\n      success = false;\n      console.log(\"Fail: CSV load\");\n      console.error(error);  \/\/ Helpful for debugging\n    }\n  }\n}\n\n\/\/ Call the function\nfetchCSVUntilSucceeded();\n\n\n\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/ preload the images \/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\nURL_generalInstructionsImg1=new Image();\n\/\/---links for Social Value Orientation\nURL_SVO_Figure1=new Image();\nURL_SVO_Figure2=new Image();\nURL_SVO_Figure3=new Image();\nURL_SVO_round1=new Image();\nURL_SVO_round2=new Image();\nURL_SVO_round3=new Image();\nURL_SVO_round4=new Image();\nURL_SVO_round5=new Image();\nURL_SVO_round6=new Image();\n\n\n\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/ Links to the images \/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\n\/\/ Note: direct usage of \"https:\/\/raw.githubusercontent...\" may cause error, so here you can concatenate \"https:\" and \"\/\/raw.githubusercontent...\"\nURL_generalInstructionsImg1.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/generalInstructionsImg1.png\";\n\/\/---links for Social Value Orientation\nURL_SVO_Figure1.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/Social%20Value%20Orientation\/SVO_Figure1.png\";\nURL_SVO_Figure2.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/Social%20Value%20Orientation\/SVO_Figure2.png\";\nURL_SVO_Figure3.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/Social%20Value%20Orientation\/SVO_Figure3.png\";\nURL_SVO_round1.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/Social%20Value%20Orientation\/SVO_round1.png\";\nURL_SVO_round2.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/Social%20Value%20Orientation\/SVO_round2.png\";\nURL_SVO_round3.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/Social%20Value%20Orientation\/SVO_round3.png\";\nURL_SVO_round4.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/Social%20Value%20Orientation\/SVO_round4.png\";\nURL_SVO_round5.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/Social%20Value%20Orientation\/SVO_round5.png\";\nURL_SVO_round6.src=\"https:\"+\"\/\/raw.githubusercontent.com\/ntu-cam-clic\/Social_Decision_Making_Tasks\/main\/Images_PlayerB_Version\/Social%20Value%20Orientation\/SVO_round6.png\";\n<\/script>","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":"","PreviousButton":"","NextButton":"","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"ntusingapore","SkinType":"templated","Skin":{"brandingId":"3394147181","templateId":"*base","overrides":{"contrast":0.299999999999999988897769753748434595763683319091796875}},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","headerMid":"","CustomStyles":{"customCSS":".Skin .QuestionOuter.Matrix{ max-width: 100%; }\r\n\r\n#CustomNextButton{\r\nbackground-color: #007ac0;  \r\nfont-family: \"Arial\";\r\nborder: none;  \r\nborder-radius: 5px; padding: 6px 23px; cursor: pointer; \r\n}"}}},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"Game Instructions In this game, you are randomly paired with another participant, referred to as...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><b><u>Game Instructions<\/u><\/b><\/div>\n\n<div style=\"text-align: left;\">In this game, you are randomly paired with another participant, referred to as \u201cPlayer A.\" This player is someone you do not know and will not knowingly meet in the future.&nbsp;<\/div>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">Player A will be making choices in 6 rounds. In each round, they will choose between 9 options. The following is one example round:<\/div>\n<div>&nbsp;<\/div>\n<img id=\"SVO_Figure1\" src=\"\">\n<div>&nbsp;<\/div>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\">Their choices will produce points for both you and Player A. For example, if Player A chooses <strong><u>Option 3<\/u><\/strong>, they will get <strong><u>88 points<\/u><\/strong>, and you will get <strong><u>63 points<\/u><\/strong>.<\/div>\n\n<div style=\"text-align: left;\">&nbsp;&nbsp;<\/div><div style=\"text-align: left;\"><\/div>\n\n<div style=\"text-align: left;\">After Player A has completed all 6 rounds, one round will be randomly selected. The points you receive in that round will be converted into your payment.<\/div><div style=\"text-align: left;\"><br><\/div>\n\n<div style=\"text-align: left;\">You will not make any decisions in this task.&nbsp;<\/div><div style=\"text-align: left;\">Player A has completed the task. Please proceed to the next page to see your points.<\/div>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\/*Place your JavaScript here to run when the page loads*\/\n\u00a0\njQuery(\".Skin .SkinInner\").css({\"min-width\": \"85%\"});\n$('#SVO_Figure1').attr(\"src\",URL_SVO_Figure1.src);\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"Q1","QuestionID":"QID1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Game Instructions In this game, you are randomly paired with another participant, referred to as...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"Round XX is chosen: Player A selected option XX . Player A gets XX points. You get XX points.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><br>\n<strong>Round <span id=\"round_chosen\">XX<\/span><\/strong> is chosen:<br>\n<br>\n<div style=\"text-align: center;\"><img id=\"SVO_round_chosen\" src=\"\" \/><\/div>\n\n<div style=\"text-align: center;\"><br>\nPlayer A selected <strong>option <span id=\"option_chosen\">XX<\/span><\/strong> .<br>\n\t\n<div style=\"text-align: center;\"><br>\nPlayer A gets <strong><span id=\"PlayerA_points\">XX<\/span><\/strong> points.\n<div style=\"text-align: center;\"><br>\nYou get <strong><span id=\"PlayerB_points\">XX<\/span><\/strong> points.<br>\t\n","DefaultChoices":false,"DataExportTag":"Q2","QuestionID":"QID2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Round XX is chosen: Player A selected option XX . Player A gets XX points. You get XX points.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tjQuery(\".Skin .SkinInner\").css({\"min-width\": \"85%\"});\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n    \/\/ values allocated to self and other for each option of the SVO task\n\tSVO_self=[[85,85,85,85,85,85,85,85,85],   \/\/round 1\n\t\t\t  [85,87,89,91,93,94,96,98,100],\n\t\t\t  [50,54,59,63,68,72,76,81,85],\n\t\t\t  [50,54,59,63,68,72,76,81,85],\n\t\t\t  [100,94,88,81,75,69,63,56,50],\n\t\t\t  [100,98,96,94,93,91,89,87,85]]  \/\/round 6\n\n\tSVO_other=[[85,76,68,59,50,41,33,24,15],\n\t\t\t   [15,19,24,28,33,37,41,46,50],\n\t\t\t   [100,98,96,94,93,91,89,87,85],\n\t\t\t   [100,89,79,68,58,47,36,26,15],\n\t\t\t   [50,56,63,69,75,81,88,94,100],\n\t\t\t   [50,54,59,63,68,72,76,81,85]]\n    \n\t\n    \/\/ URLs for the images in the 6 rounds, actual links in the header file\n\tURL_round_arrary=[URL_SVO_round1.src,\n\t\t\t\t\t  URL_SVO_round2.src,\n\t\t\t\t\t  URL_SVO_round3.src,\n\t\t\t\t\t  URL_SVO_round4.src,\n\t\t\t\t\t  URL_SVO_round5.src,\n\t\t\t\t\t  URL_SVO_round6.src]  \n\t\n\t\n\tnumSub=SVOchoices_CSV.length  \/\/ number of participants in the CSV file\n\t\n\tvar randomRowIndex = Math.floor(Math.random() * numSub) \/\/ Randomly select one participant\n\tvar SVO_row_chosen_array = SVOchoices_CSV[randomRowIndex];\t\n\tvar SVO_row_chosen_newArray=SVO_row_chosen_array.map(Number);  \/\/ change string to number\n\n\t\/\/ Randomly select a round from that row with the format [1,3,8,9,9,9]\n\tvar randomRoundIndex = Math.floor(Math.random() * 6);  \/\/ randomize between 0 and 5\n\tvar SVO_option_chosen = SVO_row_chosen_newArray[randomRoundIndex];\n\n\twhile (isNaN(SVO_option_chosen)) {  \/\/ In case there are NaN's, continue to choose until non-NAN element is chosen\n\t  randomRoundIndex = Math.floor(Math.random() * 6);\n\t  SVO_option_chosen = SVO_row_chosen_newArray[randomRoundIndex];\n\t}\n    \n\tvar SVO_row_chosen=randomRowIndex+1;\n    var SVO_round_chosen=randomRoundIndex+1;\n\t\n\t$(\"#SVO_round_chosen\").attr(\"src\",URL_round_arrary[randomRoundIndex]);\n\tdocument.getElementById(\"round_chosen\").innerHTML=SVO_round_chosen;\n\tdocument.getElementById(\"option_chosen\").innerHTML=SVO_option_chosen;\n\t\n\tvar SVO_PlayerA_points=SVO_self[SVO_round_chosen-1][SVO_option_chosen-1];\n\tvar SVO_PlayerB_points=SVO_other[SVO_round_chosen-1][SVO_option_chosen-1];\n\tdocument.getElementById(\"PlayerA_points\").innerHTML=SVO_PlayerA_points;\n\tdocument.getElementById(\"PlayerB_points\").innerHTML=SVO_PlayerB_points;\n\t\n    console.log('Selected round for your opponent =',SVO_self[SVO_round_chosen-1])\n\tconsole.log('Selected round for you =',SVO_other[SVO_round_chosen-1])\n\t\n\tconsole.log('points for your opponent =',SVO_PlayerA_points)\n\tconsole.log('points for you =',SVO_PlayerB_points)\n\n\t\/\/ prepare to save in the \n\tall_variableNames =$.merge(all_variableNames, [\"SVO_row_chosen\",\"SVO_round_chosen\", \"SVO_option_chosen\",\n                                                          \"SVO_PlayerA_points\",\"SVO_PlayerB_points\"]);\n    all_variableValues=$.merge(all_variableValues, [SVO_row_chosen,SVO_round_chosen, SVO_option_chosen,\n                                                          SVO_PlayerA_points,SVO_PlayerB_points]);         \n\t\t\t \n    var all_variableNames_Str=\"${e:\/\/Field\/all_variableNames}\" +\",\"+all_variableNames.join();\n    var all_variableValues_Str=\"${e:\/\/Field\/all_variableValues}\" +\",\"+all_variableValues.join();\n\t\t \n    if (logTurnOn) {\n\t\t\t  console.log(all_variableNames_Str );\n\t\t\t  console.log(all_variableValues_Str );\n\t\t\t  console.log(all_variableNames);\n\t\t\t  console.log(all_variableValues);}\n          \n         \n     Qualtrics.SurveyEngine.setEmbeddedData('all_variableNames', all_variableNames_Str);\n     Qualtrics.SurveyEngine.setEmbeddedData('all_variableValues', all_variableValues_Str);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_0d3rpeMXo7jedoO","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}